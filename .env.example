# ── Application ────────────────────────────────────────────
PROJECT_NAME=AI Output Verification Platform
VERSION=1.0.0
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO
ENABLE_DOCS=True
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_CONCURRENCY=1
CORS_ALLOW_ORIGINS=*
ALLOWED_HOSTS=*

# ── Verification Thresholds ───────────────────────────────
CONFIDENCE_ALLOW=0.70     # >= this score → ALLOW
CONFIDENCE_FLAG=0.50      # >= this but < ALLOW → FLAG, below → REFUSE
SIMILARITY_WEIGHT=0.40    # weight for semantic similarity in combined score
ENTAILMENT_WEIGHT=0.60    # weight for NLI entailment in combined score
STRICT_MODE_DEFAULT=False # force strict verification globally
AUTO_STRICT_BY_DOMAIN=True
STRICT_DOMAIN_KEYWORDS=medical,medicine,drug,diagnosis,treatment,prescription,legal,law,contract,liability,finance,investment,tax

# ── HuggingFace Models (downloaded automatically) ─────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
NLI_MODEL=cross-encoder/nli-deberta-v3-small
HF_TOKEN=

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./aovp_audit.db

# ── Audit Logs ────────────────────────────────────────────
AUDIT_LOG_DIR=logs/audit
AUDIT_HMAC_KEY=
HASH_SALT=
